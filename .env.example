# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=photoviewer

# Photo Library
# Set the absolute path to your photos directory on your host machine.
# Docker will securely mount this path as READ-ONLY for scanning and viewing.
# Example: PHOTOS_DIR=D:/Pictures/Organized
PHOTOS_DIR=./photos

# Security (if needed later)
# SECRET_KEY=your_secret_key
